{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "name": "html-tools",
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        }
      ]
    },
    {
      "source": "/tools/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/tool/:path*.html",
      "destination": "/tools/:path*",
      "permanent": true
    },
    {
      "source": "/tool/:path*",
      "destination": "/tools/:path*",
      "permanent": true
    },
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/tools/calculator/discount-calc",
      "destination": "/tools/calculator/discount-calculator",
      "permanent": true
    },
    {
      "source": "/tools/calculator/electricity-calc",
      "destination": "/tools/calculator/electricity-calculator",
      "permanent": true
    },
    {
      "source": "/tools/calculator/fuel-calc",
      "destination": "/tools/calculator/fuel-calculator",
      "permanent": true
    },
    {
      "source": "/tools/calculator/percentage-calc",
      "destination": "/tools/calculator/percentage",
      "permanent": true
    },
    {
      "source": "/tools/calculator/percentage-calculator",
      "destination": "/tools/calculator/percentage",
      "permanent": true
    },
    {
      "source": "/tools/calculator/salary-calc",
      "destination": "/tools/calculator/salary-calculator",
      "permanent": true
    },
    {
      "source": "/tools/calculator/subnet-calculator",
      "destination": "/tools/network/subnet-calculator",
      "permanent": true
    },
    {
      "source": "/tools/network/ip-subnet-calculator",
      "destination": "/tools/network/subnet-calculator",
      "permanent": true
    },
    {
      "source": "/tools/dev/nginx-config",
      "destination": "/tools/dev/nginx-generator",
      "permanent": true
    },
    {
      "source": "/tools/dev/nginx-config-generator",
      "destination": "/tools/dev/nginx-generator",
      "permanent": true
    },
    {
      "source": "/tools/generator/barcode-generator",
      "destination": "/tools/generator/barcode",
      "permanent": true
    },
    {
      "source": "/tools/pets/pet-age",
      "destination": "/tools/pet/pet-age-calculator",
      "permanent": true
    },
    {
      "source": "/tools/pets/pet-age-calculator",
      "destination": "/tools/pet/pet-age-calculator",
      "permanent": true
    },
    {
      "source": "/tools/real-estate/rent-vs-buy",
      "destination": "/tools/realestate/rent-vs-buy",
      "permanent": true
    }
  ]
}
